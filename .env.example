# Discord bot token (obligatorio)
DISCORD_TOKEN=tu_token_de_discord_aqui

# Prefijo de comandos
# Ejemplo: usar '-' en lugar de '!'
BOT_PREFIX=!

# Base de datos PostgreSQL (para Render o producción)
# Si no se especifica, usa archivo JSON local
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/db

# Archivo de datos persistente para la economía (opcional si usas DATABASE_URL)
DATABASE_FILE=economy.json

# Ajustes opcionales
START_BALANCE=500
DAILY_REWARD=100
